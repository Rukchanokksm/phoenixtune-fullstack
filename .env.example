# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe (required for premium features) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── App (optional) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Premium features (held until user base grows) ───────────────────────────
# Leave as "false" to hide all premium UI (PRO badge, Saved Tunes, etc).
# Flip to "true" when ready to launch paid plans.
NEXT_PUBLIC_PREMIUM_ENABLED=false

# ─── Google AdSense (optional) ───────────────────────────────────────────────
# Leave blank to disable ads
NEXT_PUBLIC_ADSENSE_CLIENT=
